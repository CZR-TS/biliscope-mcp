{
  "name": "biliscope-mcp",
  "displayName": "BiliScope MCP",
  "description": "BiliScope MCP，使用 CookieCloud 自动同步登录态，支持单 JSON 部署。",
  "version": "2.1.2",
  "author": "24730",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/365903728-oss/bilibili-mcp.git"
  },
  "runtime": {
    "type": "node",
    "command": "npx",
    "args": [
      "-y",
      "biliscope-mcp"
    ],
    "env": {
      "BILIBILI_COOKIE_SOURCE": {
        "description": "固定填 cookiecloud",
        "required": false,
        "secret": false
      },
      "COOKIECLOUD_ENDPOINT": {
        "description": "CookieCloud 服务地址",
        "required": true,
        "secret": false
      },
      "COOKIECLOUD_UUID": {
        "description": "CookieCloud 用户KEY UUID",
        "required": true,
        "secret": true
      },
      "COOKIECLOUD_PASSWORD": {
        "description": "CookieCloud 端到端加密密码",
        "required": true,
        "secret": true
      },
      "COOKIECLOUD_DOMAINS": {
        "description": "同步域名关键词，默认 bilibili.com,.bilibili.com,www.bilibili.com",
        "required": false,
        "secret": false
      },
      "COOKIE_REFRESH_INTERVAL_MINUTES": {
        "description": "Cookie 刷新间隔分钟数，默认 10",
        "required": false,
        "secret": false
      }
    }
  }
}
