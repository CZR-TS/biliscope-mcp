{
  "name": "biliscope-mcp",
  "version": "2.0.0",
  "description": "BiliScope MCP: Bilibili tools with CookieCloud auto-refresh and single JSON deployment",
  "type": "module",
  "main": "dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "biliscope-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/cli.js http",
    "dev": "smithery dev",
    "build:smithery": "smithery build",
    "check": "node dist/cli.js check",
    "prepublishOnly": "npm run build",
    "release": "semantic-release",
    "release:patch": "npm version patch && npm publish --access public",
    "release:minor": "npm version minor && npm publish --access public",
    "release:major": "npm version major && npm publish --access public"
  },
  "config": {
    "bilibili": {
      "rateLimitMs": 500,
      "requestTimeoutMs": 10000,
      "cacheSize": 100
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "bilibili",
    "cookiecloud",
    "subtitle",
    "danmaku",
    "comments"
  ],
  "author": "24730",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CZR-TS/biliscope-mcp.git"
  },
  "homepage": "https://github.com/CZR-TS/biliscope-mcp#readme",
  "bugs": {
    "url": "https://github.com/CZR-TS/biliscope-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "quick-lru": "^7.3.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@smithery/cli": "^4.5.0",
    "@types/express": "^5.0.3",
    "@types/node": "^22.19.8",
    "esbuild": "^0.24.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.2"
  }
}
